{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "allowJs": false,
    "moduleResolution": "Bundler",
    "types": [
      "node"
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "src/universe/UniverseScene.tsx",
    "src/universe/DeepSpaceStarfield.tsx",
    "src/universe/EdgeSystem.tsx",
    "src/universe/LabelSystem.tsx",
    "src/universe/NodeSystem.tsx",
    "src/universe/OrbitGuideSystem.tsx",
    "src/universe/ParticleSystem.tsx",
    "src/universe/Starfield.tsx",
    "src/universe/physics.ts",
    "src/universe/store.ts"
  ]
}
